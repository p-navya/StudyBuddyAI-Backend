# Paste inside your server { } block for api.grahmind.com (or include from sites-enabled).
# Fixes 504 Gateway Timeout on /api/chatbot/chat while Ollama runs (default nginx is often 60s).

location /api/ {
    proxy_pass http://127.0.0.1:5000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    proxy_connect_timeout 300s;
    proxy_send_timeout 300s;
    proxy_read_timeout 300s;
    send_timeout 300s;

    # Large PDF uploads (multer limit is high)
    client_max_body_size 50M;
}

# If you proxy the whole site to Node instead of only /api/, apply the same *_timeout
# and client_max_body_size on that location.
